/* pages/index/index.wxss */
.page {
  background: #f5f6f8;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.page.dark {
  background: #1a1a2e;
}

.page.dark .section {
  background: #2d2d44;
}

.page.dark .section-title {
  color: #eee;
}

.page.dark .empty-text {
  color: #ccc;
}

.page.dark .table-row {
  background: #2d2d44;
}

.page.dark .table-header {
  background: #3d3d54;
}

.page.dark .col-event, .page.dark .col-deadline {
  color: #eee;
}

.page.dark .stat-number {
  color: #eee;
}

.page.dark .plan-item {
  background: #3d3d54;
}

.page.dark .plan-text {
  color: #eee;
}

.page.dark .suggestion-item {
  background: #3d3d54;
}

.page.dark .suggestion-title {
  color: #eee;
}

.page.dark .suggestion-desc {
  color: #ccc;
}

.page.dark .analysis-label {
  color: #eee;
}

.page.dark .analysis-text {
  color: #ccc;
}

.page.ocean {
  background: #caf0f8;
}

.page.ocean .greeting {
  background: linear-gradient(135deg, #0077b6, #00b4d8);
}

.page.ocean .section {
  background: #fff;
  border: 1rpx solid rgba(0, 119, 182, 0.2);
}

.page.ocean .add-todo-btn {
  background: #0077b6;
}

.page.ocean .section-badge {
  background: rgba(0, 119, 182, 0.1);
  color: #0077b6;
}

.page.ocean .stat-number.highlight {
  color: #0077b6;
}

.page.ocean .bar-fill {
  background: #0077b6;
}

.page.ocean .analysis-dot {
  background: #0077b6;
}

.page.ocean .best-time {
  background: rgba(0, 119, 182, 0.1);
  color: #0077b6;
}

.page.sunset {
  background: #fff5f5;
}

.page.sunset .greeting {
  background: linear-gradient(135deg, #f093fb, #f5576c);
}

.page.sunset .section {
  background: #fff;
  border: 1rpx solid rgba(245, 87, 108, 0.2);
}

.page.sunset .add-todo-btn {
  background: #f5576c;
}

.page.sunset .section-badge {
  background: rgba(245, 87, 108, 0.1);
  color: #f5576c;
}

.page.sunset .stat-number.highlight {
  color: #f5576c;
}

.page.sunset .bar-fill {
  background: #f5576c;
}

.page.sunset .analysis-dot {
  background: #f5576c;
}

.page.sunset .best-time {
  background: rgba(245, 87, 108, 0.1);
  color: #f5576c;
}

.greeting {
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  padding: 40rpx 40rpx 60rpx;
  color: #fff;
}

.greeting-text {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.date-text {
  font-size: 26rpx;
  opacity: 0.85;
}

.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 20rpx;
  background: #fff;
  margin: -30rpx 20rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(74, 144, 217, 0.12);
  border: 1rpx solid rgba(74, 144, 217, 0.08);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
}

.action-item:active {
  background: rgba(74, 144, 217, 0.05);
  transform: scale(0.95);
}

.action-icon {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 10rpx;
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.1), rgba(74, 144, 217, 0.05));
  border-radius: 16rpx;
}

.action-text {
  font-size: 24rpx;
  color: #555;
  font-weight: 500;
}

.section {
  margin: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.section-badge {
  font-size: 24rpx;
  color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.edit-btn {
  font-size: 24rpx;
  color: #4A90D9;
}

.empty-todo {
  text-align: center;
  padding: 40rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.add-todo-btn {
  display: inline-block;
  padding: 16rpx 32rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
}

.todo-table {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
}

.table-header {
  display: flex;
  background: #f8f9fa;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.table-row {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  align-items: center;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row.priority-row-high {
  background: rgba(255, 107, 107, 0.03);
}

.table-row.priority-row-medium {
  background: rgba(255, 179, 71, 0.03);
}

.table-col {
  padding: 0 16rpx;
  font-size: 26rpx;
}

.col-event {
  flex: 2;
  color: #333;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.col-deadline {
  flex: 1;
  color: #666;
  text-align: center;
}

.col-status {
  flex: 1;
  text-align: center;
}

.completed-text {
  color: #999;
  text-decoration: line-through;
}

.priority-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.priority-dot.priority-high {
  background: #FF6B6B;
}

.priority-dot.priority-medium {
  background: #FFB347;
}

.priority-dot.priority-low {
  background: #98D8C8;
}

.status-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.status-done {
  background: rgba(82, 196, 26, 0.1);
  color: #52c41a;
}

.status-pending {
  background: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.chart-container {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.chart-left {
  width: 150rpx;
  height: 150rpx;
  margin-right: 30rpx;
  flex-shrink: 0;
}

.pie-canvas {
  width: 150rpx;
  height: 150rpx;
}

.pie-legend {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-top: 8rpx;
  padding: 0 10rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  flex-shrink: 0;
}

.legend-color.completed {
  background: #4A90D9;
}

.legend-color.pending {
  background: #E8E8E8;
}

.legend-text {
  font-size: 20rpx;
  color: #666;
}

.chart-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
}

.stat-number.highlight {
  color: #4A90D9;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

.weekly-chart {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.weekly-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.weekly-bars {
  display: flex;
  align-items: flex-end;
  height: 120rpx;
  gap: 16rpx;
}

.bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.bar-fill {
  width: 100%;
  background: #4A90D9;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 10rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.plan-item {
  display: flex;
  align-items: center;
  padding: 16rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.plan-item.completed {
  opacity: 0.6;
}

.plan-check {
  font-size: 28rpx;
  margin-right: 16rpx;
  color: #4A90D9;
}

.plan-text {
  flex: 1;
  font-size: 26rpx;
  color: #333;
}

.plan-progress {
  font-size: 22rpx;
  color: #999;
}

.empty-plan {
  text-align: center;
  padding: 40rpx;
}

.add-plan-btn {
  display: inline-block;
  padding: 16rpx 32rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  margin-top: 20rpx;
}

.page.ocean .add-plan-btn {
  background: #0077b6;
}

.page.sunset .add-plan-btn {
  background: #f5576c;
}

.goal-section {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.05), rgba(74, 144, 217, 0.02));
  border: 1rpx solid rgba(74, 144, 217, 0.1);
}

.goal-container {
  padding: 10rpx 0;
}

.goal-main {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.goal-duration-card,
.goal-progress-card {
  flex: 1;
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.duration-icon,
.progress-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.duration-info,
.progress-info {
  flex: 1;
}

.duration-label,
.progress-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.duration-value,
.progress-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.duration-unit,
.progress-unit {
  font-size: 22rpx;
  font-weight: 400;
  color: #999;
  margin-left: 4rpx;
}

.goal-types {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
  max-width: 100%;
  max-height: 100rpx;
  overflow: hidden;
  position: relative;
}

.goal-types::after {
  content: '';
  position: absolute;
  bottom: 0;
  right: 0;
  left: 0;
  height: 40rpx;
  background: linear-gradient(to top, rgba(245, 246, 248, 0.9), transparent);
  pointer-events: none;
}

.goal-type-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 24rpx;
  border: 1rpx solid rgba(74, 144, 217, 0.2);
  transition: all 0.2s;
}

.goal-type-item:active {
  transform: scale(0.95);
}

.goal-type-tag {
  font-size: 24rpx;
  color: #4A90D9;
  word-break: keep-all;
  white-space: nowrap;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
}

.goal-type-tag.custom {
  color: #d67b49;
}

.goal-type-item.custom {
  background: linear-gradient(135deg, rgba(255, 236, 210, 0.6), rgba(252, 182, 159, 0.4));
  border-color: rgba(214, 123, 73, 0.3);
}

.goal-type-remove {
  font-size: 24rpx;
  color: #999;
  padding: 4rpx;
  line-height: 1;
  cursor: pointer;
  opacity: 0;
  transition: opacity 0.2s;
}

.goal-type-item:active .goal-type-remove {
  opacity: 1;
}

.goal-type-item:hover .goal-type-remove {
  opacity: 1;
}

.goal-deadline {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  flex-wrap: wrap;
  gap: 8rpx;
}

.deadline-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.deadline-text {
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.deadline-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  word-break: break-all;
}

.checkin-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #f6ffed, #e6fffb);
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(82, 196, 26, 0.2);
}

.checkin-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.checkin-icon {
  font-size: 36rpx;
}

.checkin-info {
  display: flex;
  flex-direction: column;
}

.checkin-text {
  font-size: 24rpx;
  color: #666;
}

.checkin-status-text {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.checkin-status-text.checked {
  color: #52c41a;
  font-weight: 600;
}

.checkin-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
  background: linear-gradient(135deg, #52c41a, #389e0d);
  color: #fff;
  border: none;
  border-radius: 36rpx;
  font-size: 26rpx;
  line-height: 1.2;
  box-shadow: 0 4rpx 12rpx rgba(82, 196, 26, 0.3);
}

.checkin-btn.disabled {
  background: #f5f5f5;
  color: #999;
  box-shadow: none;
}

.checkin-btn-icon {
  font-size: 28rpx;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
  font-weight: 500;
}

.duration-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.duration-option {
  flex: 1;
  min-width: 140rpx;
  padding: 16rpx;
  text-align: center;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.duration-option.active {
  border-color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.custom-duration {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.custom-label {
  font-size: 26rpx;
  color: #666;
}

.custom-input {
  flex: 1;
  height: 60rpx;
  margin: 0 16rpx;
  padding: 0 16rpx;
  background: #fff;
  border: 1rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 28rpx;
  text-align: center;
}

.custom-unit {
  font-size: 26rpx;
  color: #666;
}

.goal-types-edit {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.goal-type-edit-item {
  flex: 1;
  min-width: 160rpx;
  padding: 16rpx;
  text-align: center;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.goal-type-edit-item.active {
  border-color: #4A90D9;
  background: rgba(74, 144, 217, 0.1);
  color: #4A90D9;
}

.custom-goal-type {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.custom-goal-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  background: #f8f9fa;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.add-custom-btn {
  padding: 16rpx 24rpx;
  background: #4A90D9;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.custom-types-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.custom-type-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #ffecd2, #fcb69f);
  border-radius: 20rpx;
}

.custom-type-tag {
  font-size: 24rpx;
  color: #d67b49;
}

.custom-type-remove {
  font-size: 28rpx;
  color: #d67b49;
  padding: 4rpx;
  line-height: 1;
}

.selected-types-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.selected-type-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: linear-gradient(135deg, #ffecd2, #fcb69f);
  border-radius: 20rpx;
}

.selected-type-tag {
  font-size: 24rpx;
  color: #d67b49;
}

.selected-type-remove {
  font-size: 28rpx;
  color: #d67b49;
  padding: 4rpx;
  line-height: 1;
}

.date-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #333;
}

.picker-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.suggestion-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.suggestion-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  width: 60rpx;
  text-align: center;
}

.suggestion-content {
  flex: 1;
}

.suggestion-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.suggestion-desc {
  font-size: 24rpx;
  color: #888;
  line-height: 1.6;
}

.suggestion-feedback {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.feedback-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.feedback-btn.useful {
  background: rgba(82, 196, 26, 0.1);
}

.feedback-btn.useful:active {
  background: rgba(82, 196, 26, 0.2);
  transform: scale(0.95);
}

.feedback-btn.dismiss {
  background: rgba(153, 153, 153, 0.1);
}

.feedback-btn.dismiss:active {
  background: rgba(153, 153, 153, 0.2);
  transform: scale(0.95);
}

.feedback-icon {
  font-size: 24rpx;
}

.feedback-text {
  font-size: 18rpx;
  color: #888;
  margin-top: 4rpx;
}

.section-hint {
  font-size: 22rpx;
  color: #999;
}

.analysis-container {
  display: flex;
  gap: 20rpx;
}

.analysis-card {
  flex: 1;
  border-radius: 12rpx;
  padding: 24rpx;
}

.analysis-card.strengths {
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.1), rgba(82, 196, 26, 0.05));
}

.analysis-card.weaknesses {
  background: linear-gradient(135deg, rgba(250, 173, 20, 0.1), rgba(250, 173, 20, 0.05));
}

.analysis-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.analysis-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.analysis-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.add-analysis-btn {
  font-size: 32rpx;
  color: #4A90D9;
  font-weight: 600;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 50%;
}

.analysis-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.analysis-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
  transition: background 0.2s;
}

.analysis-item:active {
  background: rgba(0, 0, 0, 0.05);
  border-radius: 8rpx;
  margin: 0 -8rpx;
  padding: 8rpx;
}

.analysis-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #4A90D9;
  margin-top: 0;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.analysis-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  flex: 1;
}

.analysis-delete-btn {
  font-size: 32rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 1;
  transition: all 0.2s;
  flex-shrink: 0;
  margin-left: 12rpx;
  background: transparent;
  border: none;
  padding: 0;
  line-height: 1;
}

.analysis-delete-btn::after {
  border: none;
}

.analysis-delete-btn:active {
  color: #FF6B6B;
  transform: scale(1.1);
}

.time-analysis {
  padding: 20rpx 0;
}

.time-bar {
  display: flex;
  align-items: flex-end;
  height: 100rpx;
  gap: 8rpx;
  padding: 0 10rpx;
}

.time-segment {
  flex: 1;
  border-radius: 4rpx;
  opacity: 0.7;
}

.time-segment.efficiency-high {
  background: #4A90D9;
}

.time-segment.efficiency-medium {
  background: #FFB347;
}

.time-segment.efficiency-low {
  background: #eee;
}

.time-segment.selected {
  opacity: 1;
  border: 2px solid #FFD700;
}

.time-labels {
  display: flex;
  justify-content: space-around;
  margin-top: 12rpx;
}

.time-label {
  font-size: 20rpx;
  color: #999;
}

.best-time {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  padding: 16rpx;
  background: rgba(74, 144, 217, 0.1);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #4A90D9;
}

.best-icon {
  margin-right: 8rpx;
}

.time-hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

.time-label.selected {
  color: #4A90D9;
  font-weight: 600;
}

.col-reflect {
  flex: 0.8;
  text-align: center;
}

.reflect-btn {
  font-size: 32rpx;
  padding: 8rpx;
  border-radius: 50%;
  background: rgba(74, 144, 217, 0.1);
}

.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-close {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
}

.slot-options {
  padding: 20rpx 30rpx;
}

.slot-option {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.slot-option:last-child {
  border-bottom: none;
}

.slot-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

.slot-checkbox.checked {
  background: #4A90D9;
  border-color: #4A90D9;
}

.slot-info {
  flex: 1;
}

.slot-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.slot-efficiency {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.slot-range {
  font-size: 24rpx;
  color: #666;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.modal-btn.confirm {
  background: #4A90D9;
  color: #fff;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.report-modal {
  max-width: 680rpx;
  max-height: 90vh;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.goal-modal {
  max-height: 85vh;
  overflow-y: auto;
}

.report-content {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 30rpx;
}

.report-section {
  margin-bottom: 30rpx;
}

.report-section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.monthly-chart {
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 24rpx;
}

.monthly-pie-canvas {
  width: 160rpx;
  height: 160rpx;
}

.monthly-stats {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.monthly-stat-item {
  text-align: center;
}

.monthly-stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.monthly-stat-value.highlight {
  color: #4A90D9;
}

.monthly-stat-label {
  font-size: 22rpx;
  color: #999;
}

.empty-habits {
  text-align: center;
  padding: 40rpx;
}

.empty-habits-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.empty-habits-text {
  font-size: 26rpx;
  color: #999;
}

.habits-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.habit-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.habit-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.habit-info {
  flex: 1;
}

.habit-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.habit-desc {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.habit-streak {
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 600;
  background: rgba(74, 144, 217, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.achievements-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.achievement-item {
  width: calc(33.33% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 10rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.achievement-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.achievement-name {
  font-size: 22rpx;
  color: #666;
  text-align: center;
}

.trend-chart {
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.trend-bars {
  display: flex;
  align-items: flex-end;
  height: 140rpx;
  gap: 16rpx;
}

.trend-bar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  height: 100%;
}

.trend-bar-fill {
  width: 100%;
  background: #4A90D9;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 10rpx;
}

.trend-bar-label {
  font-size: 20rpx;
  color: #999;
  margin-top: 8rpx;
}

.focus-section {
  background: linear-gradient(135deg, rgba(74, 144, 217, 0.08), rgba(74, 144, 217, 0.02));
  border: 1rpx solid rgba(74, 144, 217, 0.2);
}

.focus-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.focus-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.focus-priority {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 22rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.focus-priority.priority-high {
  background: #ef4444;
}

.focus-priority.priority-medium {
  background: #f59e0b;
}

.focus-priority.priority-low {
  background: #22c55e;
}

.focus-content {
  flex: 1;
}

.focus-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 6rpx;
}

.focus-deadline {
  font-size: 22rpx;
  color: #999;
}

.focus-deadline.countdown-overdue {
  color: #ef4444;
  font-weight: 600;
}

.focus-deadline.countdown-urgent {
  color: #ef4444;
  animation: pulse 1s infinite;
}

.focus-deadline.countdown-soon {
  color: #f59e0b;
}

.focus-action {
  margin-left: 16rpx;
}

.focus-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
}

.focus-checkbox.checked {
  background: #4A90D9;
  border-color: #4A90D9;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.page.dark .focus-section {
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.15), rgba(102, 126, 234, 0.05));
  border-color: rgba(102, 126, 234, 0.3);
}

.page.dark .focus-item {
  background: #2d2d44;
}

.page.dark .focus-title {
  color: #eee;
}

.page.dark .focus-deadline {
  color: #ccc;
}