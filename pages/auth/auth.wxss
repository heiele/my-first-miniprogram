/* pages/auth/auth.wxss */
.auth-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #4A90D9, #357ABD);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.auth-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.auth-logo {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.auth-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 10rpx;
}

.auth-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 50rpx;
}

.auth-notice {
  width: 100%;
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 50rpx;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.notice-item {
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}

.auth-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  text-align: center;
  border: none;
  margin-bottom: 20rpx;
}

.auth-btn.agree {
  background: #4A90D9;
  color: #fff;
}

.auth-btn.disagree {
  background: #f5f5f5;
  color: #999;
}