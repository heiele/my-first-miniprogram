/* pages/task/recycle/recycle.wxss */
.page {
  min-height: 100vh;
  padding: 20rpx;
  padding-top: calc(env(safe-area-inset-top) + 20rpx);
  box-sizing: border-box;
}

.page.light {
  background: #f5f5f5;
}

.page.dark {
  background: #1a1a1a;
}

.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
  padding: 30rpx 25rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
  margin-top: 20rpx;
}

.page.dark .header {
  background: #2a2a2a;
}

.back-btn, .clear-btn {
  padding: 15rpx 25rpx;
  font-size: 28rpx;
  margin-top: 15rpx;
}

.page.light .back-btn {
  color: #333;
}

.page.dark .back-btn {
  color: #ccc;
}

.clear-btn {
  color: #ef4444;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
}

.page.light .title {
  color: #333;
}

.page.dark .title {
  color: #fff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  margin-bottom: 15rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}

.page.dark .empty-text {
  color: #aaa;
}

.recycle-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.recycle-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.page.dark .recycle-card {
  background: #2a2a2a;
}

.task-header {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.task-checkbox {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.task-checkbox.checked {
  background: #98D8C8;
  border-color: #98D8C8;
}

.check-icon {
  font-size: 24rpx;
  color: #fff;
}

.task-info {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: 30rpx;
  font-weight: 500;
  word-break: break-all;
}

.page.light .task-title {
  color: #333;
}

.page.dark .task-title {
  color: #fff;
}

.task-title.completed {
  text-decoration: line-through;
  opacity: 0.6;
}

.task-meta {
  margin-top: 10rpx;
}

.completed-time {
  font-size: 24rpx;
  color: #999;
}

.task-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.page.dark .task-actions {
  border-color: #333;
}

.action-btn {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
}

.action-btn.restore {
  background: #98D8C8;
  color: #fff;
}

.action-btn.delete {
  background: #fef2f2;
  color: #ef4444;
}

.page.dark .action-btn.delete {
  background: #3d2a2a;
}